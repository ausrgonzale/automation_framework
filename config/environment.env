# ==================================================

# Environment Runtime Configuration

# ==================================================

# Purpose:

# Infrastructure and runtime settings used by

# shell scripts and service health checks.

#

# This file is:

# - version controlled

# - non-secret

# - environment-specific

#

# Do NOT put credentials here.

# ==================================================

# --------------------------------------------------

# Environment Identification

# --------------------------------------------------

ENVIRONMENT=development

# --------------------------------------------------

# Docker

# --------------------------------------------------

# Maximum time (seconds) to wait for Docker to start

DOCKER_START_TIMEOUT=60

# --------------------------------------------------

# Redis Configuration

# --------------------------------------------------

REDIS_CONTAINER_NAME=redis

REDIS_HOST=localhost
REDIS_PORT=6379

# Optional future settings

REDIS_START_TIMEOUT=30

# --------------------------------------------------

# Ollama Service Configuration

# --------------------------------------------------

# Base API endpoint

OLLAMA_HOST=http://localhost:11434

# --------------------------------------------------

# Ollama Runtime Resource Controls

# --------------------------------------------------

# Number of concurrent model executions

# 1 = serial

# 2 = controlled parallel (recommended)

# >2 = high throughput systems

OLLAMA_NUM_PARALLEL=2

# Maximum models kept in memory simultaneously

OLLAMA_MAX_LOADED_MODELS=1

# How long to keep model loaded when idle

OLLAMA_KEEP_ALIVE=5m

# CPU threads allowed for inference

# Recommended: ~50% of available cores

OLLAMA_NUM_THREADS=4

# --------------------------------------------------

# Health Check Behavior

# --------------------------------------------------

# Enable automatic service startup when missing

AUTO_START_SERVICES=true

# Fail immediately if a required service is down

FAIL_FAST=true

# Optional logging verbosity

LOG_LEVEL=INFO

# --------------------------------------------------

# Future Infrastructure (Safe to Leave Commented)

# --------------------------------------------------

# POSTGRES_CONTAINER_NAME=postgres

# POSTGRES_PORT=5432

# VECTOR_DB_HOST=localhost

# VECTOR_DB_PORT=6333

# WORKER_COUNT=2

# QUEUE_NAME=automation_tasks
